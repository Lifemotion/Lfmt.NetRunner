@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Applications on @Model.Hostname</h1>

@if (Model.Apps.Count == 0)
{
    <p>No applications registered. <a href="/App/Create">Deploy one</a>.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Port</th>
                <th>Mode</th>
                <th>Status</th>
                <th>Last Deploy</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (config, state) in Model.Apps)
            {
                <tr>
                    <td><a href="/App/@config.Name">@config.Name</a></td>
                    <td><a href="http://@Model.HostIp:@config.Port/" target="_blank">@config.Port</a></td>
                    <td>@(config.IsSourceMode ? "Source" : "Artifact")</td>
                    <td class="status-@state.Status.ToString().ToLower()">@state.Status</td>
                    <td>
                        @if (state.LastDeployedAt != null)
                        {
                            <span>@Model.Settings.FormatTime(state.LastDeployedAt)</span>
                            if (state.LastDeployResult == "SUCCESS")
                            {
                                <span class="status-running"> OK</span>
                            }
                            else if (state.LastDeployResult == "FAILURE")
                            {
                                <span class="status-failed"> FAIL</span>
                            }
                        }
                        else
                        {
                            <span>Never</span>
                        }
                    </td>
                    <td class="actions">
                        @if (state.Status == Lfmt.NetRunner.Models.AppStatus.Running)
                        {
                            <button class="outline secondary" onclick="apiPost('/api/apps/@config.Name/restart')">Restart</button>
                            <button class="outline secondary" onclick="apiPost('/api/apps/@config.Name/stop')">Stop</button>
                        }
                        else
                        {
                            <button class="outline" onclick="apiPost('/api/apps/@config.Name/start')">Start</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<small>Lfmt.NetRunner @Model.AppVersion &middot; @Model.Settings.FormatTime(DateTimeOffset.UtcNow) &middot; @Model.OsInfo &middot; @Model.DotnetVersion &middot; @Model.HostIp &middot; @Model.Environment</small>

@section Scripts {
    @if (Model.Settings.RefreshIntervalSeconds > 0)
    {
        <script>
            setInterval(() => location.reload(), @(Model.Settings.RefreshIntervalSeconds * 1000));
        </script>
    }
}
