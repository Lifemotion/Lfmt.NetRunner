@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Applications</h1>

@if (Model.Apps.Count == 0)
{
    <p>No applications registered. <a href="/App/Create">Deploy one</a>.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Port</th>
                <th>Status</th>
                <th>Last Deploy</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (config, state) in Model.Apps)
            {
                <tr>
                    <td><a href="/App/@config.Name">@config.Name</a></td>
                    <td><a href="http://localhost:@config.Port/" target="_blank">@config.Port</a></td>
                    <td class="status-@state.Status.ToString().ToLower()">@state.Status</td>
                    <td>@(state.LastDeployedAt?.ToString("g") ?? "Never")</td>
                    <td class="actions">
                        @if (state.Status == Lfmt.NetRunner.Models.AppStatus.Running)
                        {
                            <button class="outline secondary" onclick="apiPost('/api/apps/@config.Name/restart')">Restart</button>
                            <button class="outline secondary" onclick="apiPost('/api/apps/@config.Name/stop')">Stop</button>
                        }
                        else
                        {
                            <button class="outline" onclick="apiPost('/api/apps/@config.Name/start')">Start</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<details>
    <summary>System Info</summary>
    <table>
        <tr><td>Hostname</td><td>@Model.Hostname</td></tr>
        <tr><td>OS</td><td>@Model.OsInfo</td></tr>
        <tr><td>Runtime</td><td>@Model.DotnetVersion</td></tr>
        <tr><td>Environment</td><td>@Model.Environment</td></tr>
        <tr><td>Listen</td><td>@Model.ListenUrl</td></tr>
        <tr><td>Apps root</td><td>@Model.AppsRoot</td></tr>
        <tr><td>Apps</td><td>@Model.AppCount</td></tr>
    </table>
</details>
