@page "/App/Create"
@model Lfmt.NetRunner.Pages.App.CreateModel
@{
    ViewData["Title"] = "New Application";
}

<h1>Register New Application</h1>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <article aria-label="Error" style="background: var(--pico-del-color);">@Model.Error</article>
}

<form method="post">
    <label>
        Name
        <input type="text" name="Name" value="@Model.Input.Name" required
               pattern="[a-z0-9][a-z0-9-]*[a-z0-9]" placeholder="my-web-app" />
        <small>Lowercase letters, digits, hyphens. 2-48 characters.</small>
    </label>

    <label>
        Port
        <input type="number" name="Port" value="@Model.Input.Port" required min="1024" max="65535" />
    </label>

    <label>
        Project path (.csproj)
        <input type="text" name="Project" value="@Model.Input.Project" required
               placeholder="src/MyApp/MyApp.csproj" />
    </label>

    <fieldset>
        <legend>Health Check</legend>
        <div class="grid">
            <label>
                Path
                <input type="text" name="HealthPath" value="@Model.Input.HealthPath" />
            </label>
            <label>
                Phrase
                <input type="text" name="HealthPhrase" value="@Model.Input.HealthPhrase" />
            </label>
        </div>
        <div class="grid">
            <label>
                Timeout (s)
                <input type="number" name="HealthTimeoutSeconds" value="@Model.Input.HealthTimeoutSeconds" />
            </label>
            <label>
                Interval (s)
                <input type="number" name="HealthIntervalSeconds" value="@Model.Input.HealthIntervalSeconds" />
            </label>
        </div>
    </fieldset>

    <fieldset>
        <legend>Resources</legend>
        <div class="grid">
            <label>
                Memory
                <input type="text" name="Memory" value="@Model.Input.Memory" placeholder="256M" />
            </label>
            <label>
                CPU
                <input type="text" name="Cpu" value="@Model.Input.Cpu" placeholder="100%" />
            </label>
        </div>
    </fieldset>

    <button type="submit">Create</button>
</form>
