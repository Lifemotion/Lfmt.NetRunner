@page "/App/{name}/Env"
@model Lfmt.NetRunner.Pages.App.EnvModel
@{
    ViewData["Title"] = $"Env - {Model.Name}";
}

<h1>Environment Variables &mdash; @Model.Name</h1>

<p>Secrets stored here are loaded via <code>EnvironmentFile</code> in the systemd unit.
   Format: <code>KEY=VALUE</code>, one per line. Not visible to other applications.</p>

@if (Model.Saved)
{
    <article aria-label="Success">Saved.</article>
}

<form method="post">
    <textarea name="Content" rows="12" style="font-family: monospace;">@Model.Content</textarea>
    <button type="submit">Save</button>
</form>

<a href="/App/@Model.Name">&larr; Back to @Model.Name</a>
